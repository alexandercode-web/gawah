# .env.example
# GawaHelper Environment Configuration

# -------------------------
# Database Configuration
# -------------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=gawahelper

# -------------------------
# Application Security
# -------------------------
# Port for the Express backend
PORT=4000

# Secret used to sign JWTs. Must be a long, random string in production.
# Required in production.
JWT_SECRET=super_secret_jwt_key_here

# Initial password for the default admin account. Change this before first deploy.
# The admin will be forced to change it on first login regardless.
ADMIN_INITIAL_PASSWORD=change-me-on-deploy

# -------------------------
# Rate Limiting
# -------------------------
# Override default rate limits (optional)
# API_RATE_LIMIT_MAX=300
# AUTH_RATE_LIMIT_MAX=10

# -------------------------
# WebAuthn (Passkeys)
# -------------------------
# The Relying Party ID for WebAuthn. Usually the domain name without scheme (e.g. gawahelper.com)
RP_ID=localhost

# -------------------------
# CORS & Client
# -------------------------
# The exact origin of your frontend application (e.g. https://gawahelper.com)
CLIENT_ORIGIN=http://localhost:5173

# -------------------------
# Email Services (SMTP / Nodemailer)
# -------------------------
# To use generic SMTP providers (Resend, SendGrid, Amazon SES, Mailgun):
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=resend
# SMTP_PASS=re_123456789

# To fallback to Gmail (Not recommended for production):
# GMAIL_USER=your_email@gmail.com
# GMAIL_APP_PASSWORD=your_app_password
